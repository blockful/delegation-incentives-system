DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ens-dis
# Ponder requires DATABASE_SCHEMA when NODE_ENV=production (it auto-generates one in dev).
# Use a distinct value per environment (e.g. "staging", "prod") to isolate indexer state.
# DATABASE_SCHEMA=staging
RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BACKEND_PORT=42069
FRONTEND_PORT=3311
VITE_API_BASE_URL=/api
VITE_USE_MOCK_API=false
VITE_REOWN_PROJECT_ID=your_reown_project_id
# Local frontend dev only. Required by vite dev when VITE_API_BASE_URL is relative and mocks are disabled.
# Not used by production builds.
VITE_DEV_API_PROXY_TARGET=http://localhost:42069
# Comma-separated YYYY-MM months that are valid distribution rounds.
# If unset, any valid month can be computed.
# ROUND_MONTHS=2026-03,2026-04,2026-05
# Backend relayer proxy: bearer token forwarded server-side to the Gateful upstream.
# Required when starting the backend; the proxy module throws on startup if either is missing.
BLOCKFUL_API_TOKEN=
GATEFUL_UPSTREAM_URL=https://gateful.example.com
# Test-only override for the upstream relayer timeout (ms). Leave unset in production.
# GATEFUL_UPSTREAM_TIMEOUT_MS=15000
# Comma-separated frontend origins permitted to call this backend cross-origin.
# Required in production when the SPA hits the backend on a different origin (i.e. VITE_API_BASE_URL is an absolute URL).
# Leave unset to disable CORS entirely (same-origin only, e.g. local dev via vite proxy).
# ALLOWED_ORIGINS=https://yourapp.example.com,https://staging.yourapp.example.com
