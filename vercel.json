{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @ens-dis/frontend build",
  "outputDirectory": "apps/frontend/dist",
  "framework": null,
  "rewrites": [
    { "source": "/voters/:address", "destination": "/api/voter-html?address=:address" },
    { "source": "/((?!assets/|api/|.*\\.(png|jpg|jpeg|gif|svg|webp|ico|txt|xml|json)$).*)", "destination": "/index.html" }
  ]
}
